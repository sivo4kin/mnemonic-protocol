# Transport mode: "stdio" or "http"
MCP_TRANSPORT=http
MCP_HTTP_PORT=3000
MCP_HTTP_HOST=0.0.0.0

# Solana RPC
SOLANA_RPC_URL=http://localhost:8899

# Arweave gateway
ARWEAVE_URL=http://localhost:1984

# Keypair (auto-generated if missing)
MNEMONIC_KEYPAIR_PATH=~/.mnemonic/id.json

# Database
DATABASE_PATH=~/.mnemonic/attestations.db

# Logging
RUST_LOG=mnemonic_mcp=info
