# Transport mode: "stdio" or "http"
MCP_TRANSPORT=http
MCP_HTTP_PORT=3000
MCP_HTTP_HOST=0.0.0.0

# Solana RPC
SOLANA_RPC_URL=http://localhost:8899

# Arweave gateway
ARWEAVE_URL=http://localhost:1984

# Keypair (auto-generated if missing)
MNEMONIC_KEYPAIR_PATH=~/.mnemonic/id.json

# Database
DATABASE_PATH=~/.mnemonic/attestations.db

# Embedding provider: "hash" (offline, default) or "openai"
EMBED_PROVIDER=hash
# OPENAI_API_KEY=sk-...
# OPENAI_EMBED_MODEL=text-embedding-3-small

# TurboQuant compression bits (2, 3, or 4)
TURBO_BITS=4

# ── Storage mode ───────────────────────────────────────────────────────────────
# "local" (default): SQLite only — free, instant, no blockchain needed.
#                     Perfect for testing all 5 tools without any infra.
# "full":            Arweave + Solana + SQLite — permanent on-chain attestation.
STORAGE_MODE=local

# ── Payment ────────────────────────────────────────────────────────────────────
# Mode: "none" (open), "balance" (API key), "x402" (autonomous agents), "both"
PAYMENT_MODE=none

# Your Solana treasury pubkey (receives USDC payments)
# TREASURY_PUBKEY=<your-solana-pubkey>

# USDC SPL mint — mainnet default
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Cost per mnemonic_sign_memory call in micro-USDC (1 USDC = 1_000_000)
SIGN_MEMORY_COST_MICRO_USDC=1000

# ── Dynamic pricing (Option B) ─────────────────────────────────────────────────
# How often to refresh Irys + SOL/USDC prices (seconds). Default: 1800 (30 min)
PRICE_REFRESH_SECS=1800

# Profit margin above break-even in basis points (2000 = 20 %)
PRICING_MARGIN_BPS=2000

# Typical mnemonic_sign_memory payload size for Irys price quotes (bytes)
TYPICAL_PAYLOAD_BYTES=2048

# Solana memo transaction fee estimate in lamports (~5 000 on mainnet)
SOL_TX_FEE_LAMPORTS=5000

# Logging
RUST_LOG=mnemonic_mcp=info
