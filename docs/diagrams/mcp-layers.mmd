flowchart LR
    Client["MCP Client / Agent"]

    subgraph L1["Layer 1 — Client Interfaces"]
        MCPClient["Claude Code / Cursor / Bot"]
        SDK["Agent SDK / future higher-level client"]
    end

    subgraph L2["Layer 2 — Transport / Ingress"]
        Stdio["stdio transport"]
        Http["HTTP /mcp transport"]
        Pay["Payment gate<br/>balance / x402<br/>HTTP only, non-local mode"]
    end

    subgraph L3["Layer 3 — MCP Protocol"]
        Rpc["JSON-RPC handler<br/>initialize / tools/list / tools/call"]
    end

    subgraph L4["Layer 4 — Tool Services"]
        Who["mnemonic_whoami"]
        Sign["mnemonic_sign_memory"]
        Verify["mnemonic_verify"]
        Prove["mnemonic_prove_identity"]
        Recall["mnemonic_recall"]
    end

    subgraph L5["Layer 5 — Core Components"]
        Id["Identity / keypair"]
        Embed["Embedder<br/>fastembed or OpenAI"]
        TQ["TurboQuant compressor"]
        Codec["Codec layer<br/>canonical CBOR + blake3 + COSE"]
        Db["SQLite attestation store"]
        Sol["Solana adapter"]
        Ar["Arweave adapter"]
        Lineage["Lineage / DAG helpers"]
    end

    subgraph L6["Layer 6 — Local State"]
        KeyFile[("keypair file")]
        DbFile[("attestations.db")]
    end

    subgraph EXT["External Systems"]
        SolanaNet["Solana RPC + SPL Memo"]
        ArweaveNet["Arweave"]
        OpenAI["OpenAI embeddings API"]
    end

    Client --> MCPClient
    Client --> SDK

    MCPClient --> Stdio
    MCPClient --> Http
    SDK --> Http
    Http --> Pay
    Pay --> Rpc
    Stdio --> Rpc

    Rpc --> Who
    Rpc --> Sign
    Rpc --> Verify
    Rpc --> Prove
    Rpc --> Recall

    Who --> Id
    Who --> Db

    Sign --> Id
    Sign --> Embed
    Sign --> TQ
    Sign --> Codec
    Sign --> Db
    Sign --> Sol
    Sign --> Ar
    Sign --> Lineage

    Recall --> Id
    Recall --> Embed
    Recall --> Db

    Verify --> Codec
    Verify --> Sol
    Verify --> Ar
    Verify --> Db

    Prove --> Id

    Id --> KeyFile
    Db --> DbFile
    Embed --> OpenAI
    Sol --> SolanaNet
    Ar --> ArweaveNet

    StorageNote["Storage modes:<br/>local = SQLite only<br/>full = Arweave + Solana + SQLite"]
    RecallNote["Current recall uses full embeddings in SQLite.<br/>Compressed artifacts are created on write but not yet used as a local compressed search index."]

    StorageNote -.-> Sign
    RecallNote -.-> Recall
