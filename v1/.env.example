# Chat providers (configure the ones you use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Embedding (fastembed is default — no key needed, runs locally)
EMBED_PROVIDER=fastembed
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Database
DATABASE_PATH=mnemonic_v1.db
